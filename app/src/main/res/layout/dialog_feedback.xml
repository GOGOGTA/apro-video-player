<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvFeedbackTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/feedback_entry"
        android:textColor="@color/md_on_surface_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFeedbackDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/feedback_description"
        android:textColor="@color/md_on_surface_variant_dark"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/emailBadge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_email_badge"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvFeedbackEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feedback_email"
            android:textColor="@color/md_on_surface_dark"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvFeedbackHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/feedback_email_hint"
        android:textColor="@color/md_on_surface_variant_dark"
        android:textSize="12sp" />
</LinearLayout>
