<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/manage_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/manage_topbar"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/md_on_surface_dark"
        app:title="@string/manage_title"
        app:titleCentered="true"
        app:titleTextColor="@color/md_on_surface_dark" />

    <TextView
        android:id="@+id/tvManageHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:text="@string/manage_hint"
        android:textColor="@color/md_on_surface_variant_dark"
        android:textSize="13sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvManageGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="8dp" />

    <TextView
        android:id="@+id/tvManageCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:text="@string/video_count_default"
        android:textColor="@color/md_on_surface_variant_dark"
        android:textSize="12sp" />

</LinearLayout>
